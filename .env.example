# ── LLM API Keys ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Macro source policy.
# light: keyless original documents/articles are enough for draft generation.
# strict: require a second official verification source before auto draft readiness.
MACRO_SOURCE_POLICY=light
# Optional strict-mode reference verification.
# CUSTOMS_TRADE_API_KEY is issued by data.go.kr for 관세청_수출입총괄(GW).
CUSTOMS_TRADE_API_KEY=
DATA_GO_KR_SERVICE_KEY=
# KOSIS_API_KEY is issued by KOSIS OpenAPI. The trade table IDs must be confirmed
# from the KOSIS URL generator for the exact export/import table you want to verify.
KOSIS_API_KEY=
KOSIS_TRADE_ORG_ID=
KOSIS_TRADE_TBL_ID=
KOSIS_TRADE_ITM_ID=
KOSIS_TRADE_OBJ_L1=
MACRO_ENABLE_NPX_KORDOC=0
MACRO_ENABLE_PLAYWRIGHT_DOWNLOAD=0
MACRO_ENABLE_NETWORK_VERIFICATION=0
MACRO_SOURCE=MOTIE
MACRO_SOURCE_SYNC_LIMIT=3
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Free/Low-Cost Market Data Keys ───────────────────────────
# 공유/유출 API 키를 쓰지 말고 각 공식 사이트에서 직접 발급한 키만 입력하세요.
FRED_API_KEY=your_fred_api_key_here
BOK_ECOS_API_KEY=your_bank_of_korea_ecos_api_key_here
COINGECKO_API_KEY=your_coingecko_demo_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
NAVER_CLIENT_ID=your_naver_search_client_id_here
NAVER_CLIENT_SECRET=your_naver_search_client_secret_here

# ── Image API Keys ───────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here
FAL_KEY=your_fal_api_key_here
HF_TOKEN=your_huggingface_token_here
DASHSCOPE_BASE_URL=
FAL_IMAGE_ENDPOINT=
IMAGE_FREE_TIER_DAILY_LIMIT=20
IMAGE_DISABLE_STOCK=false
IMAGE_CONTENT_STRATEGY_OVERRIDE=
IMAGE_UPLOAD_WIDTH=800

# ── FreeLLMAPI Visual Sidecar ────────────────────────────────
# 기존 본문 생성 모델은 그대로 두고, 발행 직전 무료 시각자료 제안에만 사용합니다.
FREELLMAPI_VISUAL_SIDECAR_ENABLED=false
FREELLMAPI_BASE_URL=http://127.0.0.1:3001/v1
FREELLMAPI_API_KEY=
FREELLMAPI_VISUAL_MODEL=auto
FREELLMAPI_VISUAL_MAX_ITEMS=2
FREELLMAPI_VISUAL_TIMEOUT_SEC=20
FREELLMAPI_VISUAL_ALLOW_POLLINATIONS=true

# ── Naver Blog Credentials ───────────────────────────────────
NAVER_BLOG_ID=your_naver_blog_id_here
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_CHANNEL=
THUMBNAIL_PLACEMENT_MODE=body_top
NAVER_PUBLISH_MODE=draft
NAVER_EDITOR_PREFLIGHT=false
NAVER_EDITOR_PREFLIGHT_STRICT=true
NAVER_EDITOR_PREFLIGHT_DIR=data/editor_diagnostics
NAVER_AI_TOGGLE_MODE=metadata
NAVER_AI_TOGGLE_FORCE=false
NAVER_AI_TOGGLE_POST_VERIFY=true
NAVER_AI_TOGGLE_TELEGRAM_ALERT=true
NAVER_AI_TOGGLE_ALERT_STREAK=3
NAVER_AI_TOGGLE_REPORT_DIR=

# ── Server Settings ──────────────────────────────────────────
AUTOBLOG_API_TOKEN=
AUTOBLOG_DB_PATH=data/automation.db
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_JSON_FILE=
DRY_RUN=false

# ── Scheduler Settings ───────────────────────────────────────
SCHEDULER_DISABLED=false
SCHEDULER_DAILY_POSTS_TARGET=3
SCHEDULER_MARKET_DAILY_ENABLED=true
SCHEDULER_KRX_CLOSED_DATES=
SCHEDULER_US_CLOSED_DATES=

# ── Telegram Settings ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DRAFT_APPROVAL_ENABLED=true
TELEGRAM_DRAFT_APPROVAL_TTL_HOURS=24
TELEGRAM_DRAFT_PREVIEW_CHARS=1200
TELEGRAM_DRAFT_REVISION_TIMEOUT_MINUTES=30
